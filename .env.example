# DiploChain Environment Configuration (Example)

# --- FABRIC API SERVER (.env in /fabric-api-server) ---
DB_USER=diplochain_user
DB_PASSWORD=admin
DB_HOST=localhost
DB_NAME=diplochain_db
DB_PORT=5432
PORT=4001
COUCHDB_URL=http://admin:diplochain_couch_2025@localhost:5984

# --- AUDIT DASHBOARD (.env in /audit-dashboard) ---
VITE_API_BASE_URL=http://localhost:4001

# --- FABRIC NETWORK (.env in /fabric-network) ---
FABRIC_VERSION=2.5
CHAINCODE_NAME=diplochain
CHAINCODE_VERSION=1.3
IMAGE_TAG=latest
COMPOSE_PROJECT_NAME=diplochain
